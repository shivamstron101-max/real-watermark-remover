---
const currentYear = new Date().getFullYear();
---
<footer class="bg-[#fafafa] border-t border-[#ebebeb] py-16 px-6">
  <div class="max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
    <div class="col-span-1 md:col-span-1">
      <a href="/" class="flex items-center gap-2 font-bold text-[#171717] tracking-tight mb-4">
        <svg width="20" height="20" viewBox="0 0 76 65" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M37.5274 0L75.0548 65H0L37.5274 0Z" fill="#171717"/>
        </svg>
        <span>Real Watermark Remover</span>
      </a>
      <p class="text-sm text-[#888888]">Professional AI-powered watermark removal for images.</p>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-[#171717] mb-4">Tools</h3>
      <ul class="space-y-2">
        <li><a href="/image-watermark-remover" class="text-sm text-[#4d4d4d] hover:text-[#171717]">Image Watermark Remover</a></li>
        <li><a href="#" class="text-sm text-[#4d4d4d] hover:text-[#171717]">AI Upscaler</a></li>
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-[#171717] mb-4">Company</h3>
      <ul class="space-y-2">
        <li><a href="/about" class="text-sm text-[#4d4d4d] hover:text-[#171717]">About Us</a></li>
        <li><a href="/pricing" class="text-sm text-[#4d4d4d] hover:text-[#171717]">Pricing</a></li>
        <li><a href="#" class="text-sm text-[#4d4d4d] hover:text-[#171717]">Blog</a></li>
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-[#171717] mb-4">Legal</h3>
      <ul class="space-y-2">
        <li><a href="#" class="text-sm text-[#4d4d4d] hover:text-[#171717]">Privacy Policy</a></li>
        <li><a href="#" class="text-sm text-[#4d4d4d] hover:text-[#171717]">Terms of Service</a></li>
        <li><a href="#" class="text-sm text-[#4d4d4d] hover:text-[#171717]">Cookie Policy</a></li>
      </ul>
    </div>
  </div>
  <div class="max-w-[1400px] mx-auto mt-16 pt-8 border-t border-[#ebebeb] flex justify-between items-center">
    <p class="text-xs text-[#888888]">© {currentYear} Real Watermark Remover. All rights reserved.</p>
    <div class="flex gap-6">
      <a href="#" class="text-[#888888] hover:text-[#171717]" target="_blank" rel="noopener noreferrer"><span class="sr-only">Twitter</span><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg></a>
