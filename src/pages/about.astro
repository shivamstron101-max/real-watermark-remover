---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | Real Watermark Remover">
    <section class="py-24 bg-white">
        <div class="max-w-[1400px] mx-auto px-6">
            <div class="max-w-3xl">
                <h1 class="text-5xl md:text-6xl font-semibold tracking-tighter mb-8">We build the future of visual editing.</h1>
                <p class="text-xl text-[#4d4d4d] leading-relaxed mb-12">
                    Real Watermark Remover was born out of a simple frustration: why is it so hard to clean up a photo or video without professional skills?
                </p>
                <div class="prose prose-lg text-[#4d4d4d]">
                    <p class="mb-6">
                        Our team of AI researchers and engineers spent two years developing a proprietary neural network architecture that doesn't just "blur" watermarks—it understands the scene and reconstructs what's behind them.
                    </p>
                    <p class="mb-6">
                        Today, we serve over 1 million users worldwide, from professional photographers to social media managers, helping them reclaim their content and maintain visual purity.
                    </p>
                </div>
            </div>
            
            <div class="mt-24 grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="bg-[#fafafa] p-12 rounded-2xl border border-[#ebebeb]">
                    <h2 class="text-2xl font-semibold mb-4">Our Mission</h2>
                    <p class="text-[#4d4d4d]">To democratize professional-grade visual editing through accessible, high-performance AI tools.</p>
                </div>
                <div class="bg-[#fafafa] p-12 rounded-2xl border border-[#ebebeb]">
                    <h2 class="text-2xl font-semibold mb-4">Our Values</h2>
                    <ul class="space-y-4 text-[#4d4d4d]">
                        <li class="flex gap-3"><span class="text-[#171717] font-bold">Quality First:</span> We never compromise on the resolution or integrity of your media.</li>
                        <li class="flex gap-3"><span class="text-[#171717] font-bold">Privacy:</span> Your data is your own. We process, we don't store.</li>
                        <li class="flex gap-3"><span class="text-[#171717] font-bold">Innovation:</span> We're constantly pushing the boundaries of what's possible with Generative AI.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
</Layout>
